{
  "name": "@logic-arena/engine",
  "version": "1.0.0",
  "description": "Core Game Engine for Logic Arena",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./constants": {
      "types": "./dist/constants.d.ts",
      "require": "./dist/constants.js",
      "default": "./dist/constants.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch --preserveWatchOutput",
    "dev": "ts-node src/index.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "typescript": "^5.5.0",
    "ts-node": "^10.9.2"
  }
}
